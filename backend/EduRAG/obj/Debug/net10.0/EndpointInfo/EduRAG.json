            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          }
        }
      },
      "CreateCollectionRequest": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 120,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "type": "string"
          }
        }
      },
      "CreateDocumentRequest": {
        "required": [
          "title",
          "type"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 150,
            "type": "string"
          },
          "type": {
            "pattern": "^(PDF|PPTX|DOCX)$",
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "type": "string"
          }
        }
      },
      "Document": {
        "type": "object",
